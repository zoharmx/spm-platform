rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      // Safe: returns 'viewer' if the user document doesn't exist yet
      let u = userDoc();
      return u != null ? u.data.get('role', 'viewer') : 'viewer';
    }

    function hasRole(minimum) {
      let weights = {
        'viewer':   1,
        'mecanico': 2,
        'operador': 3,
        'manager':  4,
        'admin':    5
      };
      return isAuth() && weights[userRole()] >= weights[minimum];
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read/write their own profile
      allow read, write: if isAuth() && request.auth.uid == userId;
      // Managers+ can read all user profiles (role management UI)
      allow read: if hasRole('manager');
      // Admins can update any user's role
      allow write: if hasRole('admin');
    }

    // ── Service Tickets ─────────────────────────────────────────────────────
    match /service_tickets/{ticketId} {
      // Operators+ can read and write all tickets (CRM module)
      allow read, write: if hasRole('operador');
      // Mechanics can read tickets assigned to them and update status/notes
      allow read:   if isAuth() && resource != null && resource.data.mechanicId == request.auth.uid;
      allow update: if isAuth() && resource != null && resource.data.mechanicId == request.auth.uid;
      // Clients can read their own tickets (portal module)
      allow read: if isAuth() && resource != null && (
        resource.data.clientEmail == request.auth.token.email ||
        resource.data.clientId == request.auth.uid
      );
    }

    // ── Clients ─────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read, write: if hasRole('operador');
      allow read: if isAuth() && resource != null && resource.data.uid == request.auth.uid;
    }

    // ── Mechanics ───────────────────────────────────────────────────────────
    match /mechanics/{mechanicId} {
      allow read: if isAuth();
      allow write: if hasRole('manager');
      // Mechanics can update their own location/status
      allow update: if isAuth() && resource != null && resource.data.uid == request.auth.uid;
    }

    // ── Motorcycles ─────────────────────────────────────────────────────────
    match /motorcycles/{motoId} {
      // Clients manage their own motorcycles
      allow read, write: if isAuth() && (
        resource == null ||
        resource.data.clientId == request.auth.uid
      );
      // Operators can read all motorcycles
      allow read: if hasRole('operador');
    }

    // ── Platform settings ───────────────────────────────────────────────────
    match /settings/{document} {
      allow read: if isAuth();
      allow write: if hasRole('manager');
    }

    // ── Atomic counters ─────────────────────────────────────────────────────
    // Operators need client-side access to generate sequential SPM-XXXX IDs
    // via Firestore transactions (createTicketDirect in lib/firestore/tickets.ts).
    // The quotes API also uses Admin SDK (bypasses rules) so this is safe.
    match /_counters/{document} {
      allow read, write: if hasRole('operador');
    }

    // ── Lead data ────────────────────────────────────────────────────────────
    match /leads/{leadId} {
      allow read: if hasRole('operador');
      // Leads are created server-side via Admin SDK (quotes API)
      allow write: if false;
    }

    // ── Product Catalog ──────────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone (including unauthenticated) can read active products — public marketplace
      allow read: if true;
      // Managers+ can create and update; Admins can delete (soft-delete via isActive)
      allow create, update: if hasRole('manager');
      allow delete: if hasRole('admin');
    }

    // ── Vendors (Proveedores) ────────────────────────────────────────────────
    match /vendors/{vendorId} {
      allow read: if hasRole('operador');
      allow create, update: if hasRole('manager');
      allow delete: if hasRole('admin');
    }

    // ── Purchase Orders (Órdenes de Compra) ──────────────────────────────────
    match /purchase_orders/{orderId} {
      allow read: if hasRole('manager');
      allow create, update: if hasRole('manager');
      allow delete: if hasRole('admin');
    }

    // ── Inventory Movements (Bitácora) ───────────────────────────────────────
    // Written exclusively server-side via Admin SDK — no client writes
    match /inventory_movements/{movementId} {
      allow read: if hasRole('manager');
      allow write: if false;
    }

  }
}
